---
import Layout from '../layouts/Layout.astro';
---

<style>
  .error-code {
    font-size: clamp(8rem, 20vw, 16rem);
    line-height: 1;
    background: linear-gradient(135deg, #1e293b 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.05em;
  }
</style>

<Layout title="Page Not Found - Mobile Phone Price in Bangladesh" description="The page you're looking for doesn't exist. Browse our collection of mobile phones, compare devices, or search for any phone in Bangladesh.">
  <div class="min-h-[70vh] flex items-center justify-center px-6 py-20">
    <div class="text-center max-w-lg">
      <div class="error-code font-black">404</div>
      <h1 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mt-4">
        Page Not Found
      </h1>
      <p class="text-slate-500 font-medium mt-4 leading-relaxed">
        The page you're looking for doesn't exist. It might have been moved, deleted, or the URL was typed incorrectly.
      </p>

      <div class="mt-10 space-y-6">
        <!-- Quick Links -->
        <div class="bg-white rounded-3xl border border-slate-200 p-8 shadow-sm">
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 mb-6">Where would you like to go?</p>
          <div class="grid grid-cols-2 gap-3">
            <a href="/" class="flex flex-col items-center gap-2 p-5 bg-slate-50 rounded-2xl border border-slate-100 hover:border-blue-400 hover:bg-blue-50 transition-all group">
              <svg class="w-6 h-6 text-slate-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
              <span class="text-[10px] font-black uppercase tracking-widest text-slate-700 group-hover:text-blue-700">Home</span>
            </a>
            <a href="/category/latest" class="flex flex-col items-center gap-2 p-5 bg-slate-50 rounded-2xl border border-slate-100 hover:border-blue-400 hover:bg-blue-50 transition-all group">
              <svg class="w-6 h-6 text-slate-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M98.19 21l-11.96-6.29L.19 21V3h20v18zM5 7v4m4-4v4m4-4v4m4-4v4" />
              </svg>
              <span class="text-[10px] font-black uppercase tracking-widest text-slate-700 group-hover:text-blue-700">Latest</span>
            </a>
            <a href="/compare" class="flex flex-col items-center gap-2 p-5 bg-slate-50 rounded-2xl border border-slate-100 hover:border-blue-400 hover:bg-blue-50 transition-all group">
              <svg class="w-6 h-6 text-slate-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
              </svg>
              <span class="text-[10px] font-black uppercase tracking-widest text-slate-700 group-hover:text-blue-700">Compare</span>
            </a>
            <a href="/brand/apple" class="flex flex-col items-center gap-2 p-5 bg-slate-50 rounded-2xl border border-slate-100 hover:border-blue-400 hover:bg-blue-50 transition-all group">
              <svg class="w-6 h-6 text-slate-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5" />
              </svg>
              <span class="text-[10px] font-black uppercase tracking-widest text-slate-700 group-hover:text-blue-700">Brands</span>
            </a>
          </div>
        </div>

        <!-- Search Suggestion -->
        <p class="text-sm font-bold text-slate-500">
          Or use the <span class="text-blue-600 font-black">search bar</span> above to find any phone you're looking for.
        </p>
      </div>
    </div>
  </div>
</Layout>
