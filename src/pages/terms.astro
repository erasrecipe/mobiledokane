---
import Layout from '../layouts/Layout.astro';

const lastUpdated = "March 13, 2026";
---

<Layout title="Terms of Service - Mobile Dokane | User Agreement Bangladesh" description="Read Mobile Dokane's terms of service. Learn about our data accuracy standards, pricing disclaimers, and user rights. Updated March 2026.">
  
  <!-- TERMS HERO -->
  <section class="bg-white py-24 border-b border-slate-200 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-50 rounded-full blur-[120px] opacity-50 -mr-40 -mt-40"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
      <nav class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-8">
        <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-900">Terms</span>
      </nav>
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tighter uppercase mb-6">Terms of Service</h1>
      <p class="text-sm font-bold text-slate-500 uppercase tracking-widest">Last Updated: {lastUpdated}</p>
    </div>
  </section>

  <!-- TERMS CONTENT -->
  <section class="bg-[#eeeeee] py-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-white p-8 sm:p-16 rounded-[3rem] border border-slate-200 shadow-sm space-y-16">
        
        <!-- 1. Acceptance of Terms -->
        <div>
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-slate-900 rounded-full"></span>
            1. Acceptance of Terms
          </h2>
          <p class="text-base font-bold text-slate-600 leading-relaxed">
            By accessing or using the Mobile Dokane website, you acknowledge that you have read, understood, and agree to be bound by these Terms of Service. If you do not agree with any part of these terms, you are prohibited from using or accessing this site.
          </p>
        </div>

        <!-- 2. No Seller Relationship -->
        <div class="bg-red-50 p-8 rounded-3xl border border-red-100">
          <h2 class="text-2xl font-black text-red-900 uppercase tracking-tight mb-4 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-red-600 rounded-full"></span>
            2. Crucial Disclaimer: No Seller Relationship
          </h2>
          <p class="text-base font-black text-red-800 leading-relaxed mb-4 uppercase italic underline decoration-2 underline-offset-4">
            MOBILE DOKANE IS NOT A RETAILER, SHOP, OR SELLER.
          </p>
          <div class="space-y-4 text-sm font-bold text-red-700 leading-relaxed">
            <p>We do not sell mobile phones, accessories, or any physical goods. We are a pure information engine providing real-time data aggregation for the Bangladesh market.</p>
            <p>Any commercial transaction you enter into after viewing data on this site is exclusively between you and the respective third-party retailer. Mobile Dokane is not a party to, and has no responsibility for, such transactions.</p>
          </div>
        </div>

        <!-- 3. Market Data Accuracy -->
        <div>
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-slate-900 rounded-full"></span>
            3. Accuracy of Information
          </h2>
          <p class="text-base font-bold text-slate-600 leading-relaxed mb-6">
            The data on Mobile Dokane is aggregated from various physical and online shops in Bangladesh (Bashundhara City, Jamuna Future Park, etc.).
          </p>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
              <h3 class="text-[10px] font-black uppercase text-slate-400 mb-2">Price Estimates</h3>
              <p class="text-xs font-bold text-slate-600">Unofficial and used prices are estimates based on market scans and may vary by shop, location, and daily dollar rates.</p>
            </div>
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
              <h3 class="text-[10px] font-black uppercase text-slate-400 mb-2">Technical Specs</h3>
              <p class="text-xs font-bold text-slate-600">Specifications and benchmarks are sourced from manufacturers and laboratory tests. Real-world performance may vary.</p>
            </div>
          </div>
        </div>

        <!-- 4. User Conduct -->
        <div>
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-slate-900 rounded-full"></span>
            4. User Conduct & Restrictions
          </h2>
          <div class="space-y-4 text-base font-bold text-slate-600 leading-relaxed">
            <p>Users are strictly prohibited from:</p>
            <ul class="list-disc pl-6 space-y-2 text-sm">
              <li>Using automated systems (bots, scrapers, crawlers) to extract our pricing or spec data.</li>
              <li>Attempting to interfere with the proper working of the site or decision engine.</li>
              <li>Reproducing our curated technical benchmarks or price analytics for commercial gain without written consent.</li>
            </ul>
          </div>
        </div>

        <!-- 5. Intellectual Property -->
        <div>
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-slate-900 rounded-full"></span>
            5. Intellectual Property
          </h2>
          <p class="text-base font-bold text-slate-600 leading-relaxed">
            All original content, including our "Decision Engine" logic, visual data representations, and site design, is the intellectual property of Mobile Dokane. Third-party brand names, logos, and device images are the property of their respective owners (e.g., Apple Inc., Samsung Electronics).
          </p>
        </div>

        <!-- 6. Limitation of Liability -->
        <div>
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-slate-900 rounded-full"></span>
            6. Limitation of Liability
          </h2>
          <p class="text-base font-bold text-slate-600 leading-relaxed">
            Mobile Dokane shall not be liable for any direct, indirect, incidental, or consequential damages resulting from the use or inability to use our platform or for the cost of procurement of substitute goods or resulting from any goods purchased or obtained based on information from our site.
          </p>
        </div>

        <!-- 7. Contact Information -->
        <div class="pt-12 border-t border-slate-100 text-center">
          <h2 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-4">Questions?</h2>
          <p class="text-sm font-bold text-slate-500 leading-relaxed">
            If you have any questions regarding these Terms of Service, please contact us at:
            <br/><span class="text-blue-600 font-black">legal@mobiledokane.com.bd</span>
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>
