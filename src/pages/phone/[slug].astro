---
import Layout from '../../layouts/Layout.astro';
import searchIndex from '../../data/search-index.json';
import { getAllPhones } from '../../utils/phones';
import { formatPrice, formatTechValue } from '../../utils/format';

export function getStaticPaths() {
  const phones = getAllPhones();
  return phones.map(phone => ({
    params: { slug: phone.slug },
    props: { phone },
  }));
}

const { slug } = Astro.params;
const phoneData = Astro.props.phone;
const phone = phoneData;

const currentMonthYear = new Date().toLocaleString('en-US', { month: 'long', year: 'numeric' });
const seoTitle = `${phone.name} Price in Bangladesh - ${currentMonthYear}`;
const seoDescription = `${phone.name} price in BD: ${formatPrice(phone.prices.unofficial)}. ${phone.overview?.chipset || 'Advanced chip'}, ${phone.overview?.camera || 'pro camera'}, ${phone.overview?.battery || 'long-lasting battery'}. Full specs & benchmarks inside.`;

const specCategories = Object.entries(phone.specs_v2 || {});

// Define benchmark categories for easier rendering
const benchmarkCategories = [
  { id: 'performance_test', title: 'Power & Speed', color: 'bg-blue-600', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z' },
  { id: 'display_test', title: 'Screen Fidelity', color: 'bg-indigo-600', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3' },
  { id: 'battery_test', title: 'Endurance', color: 'bg-emerald-600', icon: 'M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z' },
  { id: 'camera_test', title: 'Optics Score', color: 'bg-rose-600', icon: 'M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316zM16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z' }
];

// Simple bar width calculator
const getBarWidth = (value: string) => {
  const num = parseInt(value.replace(/[^0-9]/g, ''));
  if (isNaN(num)) return '70%';
  if (num > 1000000) return '100%'; 
  if (num > 5000) return '95%'; 
  if (num > 1000) return '85%'; 
  if (num > 100) return '90%'; 
  return '60%';
};

// JSON-LD Schemas for SEO
const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": phone.name,
  "image": [phone.image],
  "description": seoDescription,
  "brand": {
    "@type": "Brand",
    "name": phone.brand
  },
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": phone.prices.unofficial,
    "highPrice": phone.prices.official,
    "priceCurrency": "BDT",
    "offerCount": phone.prices.variants?.length || 1,
    "availability": "https://schema.org/InStock",
    "offers": (phone.prices.variants || []).map(v => ({
      "@type": "Offer",
      "price": v.price,
      "priceCurrency": "BDT",
      "itemCondition": "https://schema.org/NewCondition",
      "availability": "https://schema.org/InStock",
      "name": `${phone.name} ${v.ram} RAM + ${v.storage}`,
      "seller": {
        "@type": "Organization",
        "name": "Mobile Dokane"
      }
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiledokane.com" },
    { "@type": "ListItem", "position": 2, "name": phone.brand, "item": `https://mobiledokane.com/brand/${phone.brand.toLowerCase()}` },
    { "@type": "ListItem", "position": 3, "name": phone.name, "item": `https://mobiledokane.com/phone/${phone.slug}` }
  ]
};

const faqSchema = phone.detailed_content?.faq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": phone.detailed_content.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
} : null;
---

<Layout title={seoTitle} description={seoDescription} image={phone.image} url={`https://mobiledokane.com/phone/${phone.slug}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <!-- ═══════════════════════════════════════════════════════════
       MOBILE OPTIMIZED STICKY NAV
  ═══════════════════════════════════════════════════════════ -->
  <nav class="bg-white border-b border-slate-200 sticky top-16 z-40 overflow-x-auto no-scrollbar">
    <div class="max-w-5xl mx-auto px-4 h-12 flex items-center justify-between min-w-max md:min-w-0">
      <div class="flex items-center gap-1.5 text-[9px] font-bold uppercase tracking-widest text-slate-500 mr-8">
        <a href="/" class="hover:text-blue-600 transition-colors flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
          Home
        </a>
        <span class="text-slate-300">/</span>
        <a href={`/brand/${phone.brand.toLowerCase()}`} class="hover:text-blue-600 transition-colors">{phone.brand}</a>
        <span class="text-slate-300">/</span>
        <span class="text-blue-600 font-black truncate max-w-[120px]">{phone.name}</span>
      </div>
      <div class="flex gap-4 md:gap-8">
         <a href="#overview" class="text-[10px] font-black uppercase tracking-widest text-slate-700 hover:text-blue-600">Overview</a>
         <a href="#specs" class="text-[10px] font-black uppercase tracking-widest text-slate-700 hover:text-blue-600">Specs</a>
         <a href="#benchmarks" class="text-[10px] font-black uppercase tracking-widest text-slate-700 hover:text-blue-600">Benchmarks</a>
         <a href="#price" class="text-[10px] font-black uppercase tracking-widest text-slate-700 hover:text-blue-600">Pricing</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════════
       HERO SECTION (Mobile-First Layout)
  ═══════════════════════════════════════════════════════════ -->
  <section id="overview" class="bg-white py-8 lg:py-14 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col lg:grid lg:grid-cols-12 gap-8 lg:gap-10 items-center lg:items-start">
        
        <!-- Image Area -->
        <div class="w-full lg:col-span-5 flex flex-col items-center">
          <div class="relative group w-full max-w-[260px] lg:max-w-[300px] transition-transform duration-500 hover:scale-[1.02]">
            <div class="absolute inset-0 bg-white rounded-[2rem] lg:rounded-[2.5rem] shadow-sm border border-slate-200"></div>
            <img
              id="main-phone-image"
              src={phone.image}
              alt={`${phone.name} — official product photo`}
              width="400"
              height="500"
              class="relative w-full h-auto object-contain drop-shadow-xl z-10 py-6 lg:py-10 transition-opacity duration-300"
              onerror="this.onerror=null;this.src='data:image/svg+xml;base64,';"
              decoding="async"
            />
          </div>

          <!-- COLOR SELECTOR -->
          {phone.color_variants && (
            <div class="mt-8 flex flex-col items-center gap-4">
              <div class="flex flex-col items-center">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-900">Available Colors</p>
                <div class="h-0.5 w-6 bg-blue-600 mt-1 rounded-full"></div>
              </div>
              <div class="flex flex-wrap justify-center gap-4">
                {phone.color_variants.map((color, idx) => (
                  <button
                    class={`color-swatch relative w-10 h-10 flex items-center justify-center rounded-full border-2 transition-all duration-300 hover:scale-110 active:scale-95 ${idx === 0 ? 'border-blue-600 ring-2 ring-blue-100' : 'border-slate-200'}`}
                    style={`background-color: ${color.color}`}
                    title={color.name}
                    data-image={color.image}
                    aria-label={`${color.name} color variant`}
                  >
                    <span class="w-7 h-7 rounded-full" style={`background-color: ${color.color}`}></span>
                  </button>
                ))}
              </div>
              <p id="color-name" class="text-[10px] font-black text-slate-900 uppercase tracking-widest">{phone.color_variants[0].name}</p>
            </div>
          )}
        </div>

        <!-- Info Area -->
        <div class="w-full lg:col-span-7">
          <div class="flex flex-wrap items-center gap-3 mb-4">
             <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-[8px] font-black uppercase tracking-[0.2em] border border-blue-100">
               <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
               Verified Specs
             </div>
             {phone.rating && (
                <div class="flex items-center gap-1.5 bg-white/50 px-2 py-1 rounded-full border border-slate-200">
                   <div class="flex gap-0.5">
                      {[1,2,3,4,5].map(i => (
                         <div class={`w-2.5 h-2.5 rounded-full ${i <= Math.floor(phone.rating) ? 'bg-amber-400' : 'bg-slate-300'}`}></div>
                      ))}
                   </div>
                   <span class="text-[10px] font-black text-slate-800">{phone.rating}</span>
                </div>
             )}
          </div>

          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black text-slate-800 tracking-tight mb-6 leading-tight text-center lg:text-left">
            {phone.name}
          </h1>

          <!-- VARIANT PRICING (Mobile Scrollable) -->
          <div class="flex overflow-x-auto no-scrollbar gap-2 mb-8 pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-3 snap-x snap-mandatory">
             {phone.prices.variants?.map((v, idx) => (
                <div class={`flex-shrink-0 w-36 sm:w-auto py-1.5 px-3 rounded-lg border transition-all duration-300 snap-center ${idx === 0 ? 'bg-white border-blue-500 ring-1 ring-blue-500 shadow-sm' : 'bg-white/50 border-slate-200'}`}>
                   <p class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-0.5">{v.ram} + {v.storage}</p>
                   <p class="text-sm sm:text-base font-black text-slate-900 tracking-tight">{formatPrice(v.price)}</p>
                   {idx === 0 && <span class="text-[6px] font-bold text-blue-600 uppercase tracking-tighter">Recommended</span>}
                </div>
             ))}
          </div>

          <!-- Quick Specs Grid -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {[
              { label: 'Chipset', value: phone.overview?.chipset, iconColor: 'bg-blue-600', borderColor: 'border-blue-200' },
              { label: 'Display', value: phone.overview?.display, iconColor: 'bg-indigo-600', borderColor: 'border-indigo-200' },
              { label: 'Camera', value: phone.overview?.camera, iconColor: 'bg-emerald-600', borderColor: 'border-emerald-200' },
              { label: 'Battery', value: phone.overview?.battery, iconColor: 'bg-amber-600', borderColor: 'border-amber-200' },
              { label: 'RAM', value: phone.overview?.ram, iconColor: 'bg-purple-600', borderColor: 'border-purple-200' },
              { label: 'Storage', value: phone.overview?.storage, iconColor: 'bg-rose-600', borderColor: 'border-rose-200' }
            ].map(item => (
              <div class={`group p-3 sm:p-4 bg-white border-2 ${item.borderColor} shadow-sm rounded-xl hover:shadow-md transition-all`}>
                <div class="flex items-center gap-2 mb-2">
                  <span class={`w-1.5 h-4 ${item.iconColor} rounded-full`}></span>
                  <p class="text-[11px] font-black text-slate-500 uppercase tracking-widest">{item.label}</p>
                </div>
                <p class="text-[13px] sm:text-sm font-black text-slate-900 leading-tight">
                  {item.value || '—'}
                </p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       DETAILED OVERVIEW (Expandable)
  ═══════════════════════════════════════════════════════════ -->
  {phone.detailed_content && (
    <section class="bg-[#eeeeee] py-12 border-b border-slate-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tighter mb-6 uppercase text-center">
          Detailed Overview
        </h2>
        
        <div class="relative group">
          <p id="overview-text" class="text-base sm:text-lg font-medium text-slate-600 leading-relaxed text-center line-clamp-2 transition-all duration-500">
            {phone.detailed_content.intro}
          </p>

          <div class="flex justify-center mt-4">
            <button id="expand-btn" class="flex flex-col items-center gap-1 group/btn outline-none min-h-[48px] justify-center px-8">
               <span id="expand-label" class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 group-hover/btn:text-blue-600 transition-colors">Read More</span>
               <svg id="expand-icon" class="w-5 h-5 text-slate-300 group-hover/btn:text-blue-500 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
               </svg>
            </button>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       PROS & CONS (Stacked Mobile)
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-[#eeeeee] py-8 sm:py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-6 sm:gap-8">
        <div class="bg-white border-t-4 border-green-600 p-6 sm:p-8 rounded-b-2xl shadow-sm">
           <h3 class="text-xs font-black text-green-700 uppercase tracking-widest mb-6 flex items-center gap-2">Strengths</h3>
           <ul class="space-y-4">
              {phone.pros?.map(pro => (
                <li class="flex items-start gap-3">
                   <div class="w-1 h-1 rounded-full bg-green-500 mt-2 flex-shrink-0"></div>
                   <p class="text-sm font-bold text-slate-700 leading-tight">{pro}</p>
                </li>
              ))}
           </ul>
        </div>
        <div class="bg-white border-t-4 border-red-600 p-6 sm:p-8 rounded-b-2xl shadow-sm">
           <h3 class="text-xs font-black text-red-700 uppercase tracking-widest mb-6 flex items-center gap-2">Weaknesses</h3>
           <ul class="space-y-4">
              {phone.cons?.map(con => (
                <li class="flex items-start gap-3">
                   <div class="w-1 h-1 rounded-full bg-red-500 mt-2 flex-shrink-0"></div>
                   <p class="text-sm font-bold text-slate-700 leading-tight">{con}</p>
                </li>
              ))}
           </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       EXPERT EVALUATION (Mobile Optimized)
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-[#eeeeee] py-8 sm:py-12 border-b border-slate-200 expert-evaluation-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm flex flex-col md:flex-row">
        <div class="bg-slate-900 text-white p-8 md:w-1/3 flex flex-col justify-center items-center text-center">
           <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-60 mb-2">Overall Rating</p>
           <div class="text-6xl font-black tracking-tighter mb-2">{phone.rating}</div>
           <div class="flex gap-1">
              {[1,2,3,4,5].map(i => (
                 <div class={`w-2 h-2 rounded-full ${i <= Math.floor(phone.rating) ? 'bg-amber-400' : 'bg-slate-700'}`}></div>
              ))}
           </div>
        </div>
        <div class="p-6 sm:p-8 md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 sm:gap-y-6">
           {[
              { label: 'Performance', score: phone.rating_details?.performance || phone.rating || 0 },
              { label: 'Camera', score: phone.rating_details?.camera || phone.rating || 0 },
              { label: 'Display', score: phone.rating_details?.display || phone.rating || 0 },
              { label: 'Battery', score: phone.rating_details?.battery || phone.rating || 0 },
              { label: 'Design', score: phone.rating_details?.design || phone.rating || 0 }
           ].map(item => (
              <div class="flex items-center justify-between gap-4">
                 <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 w-24">{item.label}</span>
                 <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                    <div 
                      class="h-full bg-slate-800 rounded-full transition-all duration-1000 ease-out opacity-0 rating-progress-bar" 
                      data-target-width={`${(item.score / 5) * 100}%`}
                      style="width: 0%"
                    ></div>
                 </div>
                 <span class="text-[11px] font-black text-slate-900 w-8 text-right">{item.score.toFixed(1)}</span>
              </div>
           ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SPECIFICATIONS (Stacked on Mobile)
  ═══════════════════════════════════════════════════════════ -->
  <section id="specs" class="bg-[#eeeeee] py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="mb-12 text-center">
        <h2 class="text-3xl sm:text-4xl font-black text-slate-800 tracking-tighter uppercase mb-2">Technical Specifications</h2>
        <div class="h-1.5 w-20 bg-slate-400 mx-auto rounded-full"></div>
      </div>
      <div class="space-y-8 sm:space-y-12">
        {specCategories.map(([category, items]) => (
          <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
            <div class="bg-slate-800 text-white px-6 py-3">
              <h3 class="text-sm font-bold uppercase tracking-[0.3em]">{category}</h3>
            </div>
            <div class="bg-white divide-y divide-slate-100">
              {Object.entries(items).map(([key, value]) => (
                <div class="grid grid-cols-4 hover:bg-slate-50 transition-colors">
                  <div class="col-span-1 p-3 border-r border-slate-100 bg-slate-50/30 flex items-center min-w-0">
                    <span class="text-[9px] sm:text-xs font-black text-slate-900 uppercase tracking-tighter leading-tight break-words">{key}</span>
                  </div>
                  <div class="col-span-3 p-3 min-w-0">
                    <span class="text-[13px] sm:text-sm font-bold text-slate-700 leading-relaxed whitespace-pre-line break-words">{formatTechValue(value)}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BENCHMARKS (High Readability Mobile)
  ═══════════════════════════════════════════════════════════ -->
  <section id="benchmarks" class="bg-[#eeeeee] py-12 border-t border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-10 text-center">
         <p class="text-[10px] font-black text-blue-600 uppercase tracking-[0.4em] mb-1.5">Laboratory Benchmarks</p>
         <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tighter">Verified Power Metrics</h2>
      </div>
      {phone.benchmarks_v2 ? (
        <div class="grid md:grid-cols-2 gap-6">
           {benchmarkCategories.map((cat) => (
              phone.benchmarks_v2[cat.id] && (
                <div class="bg-white p-6 border border-slate-200 shadow-sm rounded-xl hover:border-blue-200 transition-colors group">
                   <div class="flex items-center gap-2.5 mb-6">
                      <div class={`w-7 h-7 ${cat.color} text-white rounded-lg flex items-center justify-center`}>
                         <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
                         </svg>
                      </div>
                      <h3 class="text-base font-black text-slate-900 uppercase tracking-tight">{cat.title}</h3>
                   </div>
                   <div class="space-y-6">
                      {Object.values(phone.benchmarks_v2[cat.id]).map((test: any) => (
                         <div>
                            <div class="flex justify-between items-end mb-1.5">
                               <div>
                                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-0.5">{test.label}</p>
                                  <p class="text-lg font-black text-slate-900 tracking-tighter">{test.value}</p>
                               </div>
                               {test.status && <span class="text-[8px] font-black bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded uppercase">{test.status}</span>}
                            </div>
                            <div class="w-full h-1 bg-slate-100 rounded-full overflow-hidden">
                               <div class={`h-full ${cat.color} transition-all duration-1000 ease-out`} style={`width: ${getBarWidth(test.value)}`}></div>
                            </div>
                         </div>
                      ))}
                   </div>
                </div>
              )
           ))}
        </div>
      ) : (
        <div class="bg-white p-10 border border-dashed border-slate-200 text-center rounded-2xl">
           <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Laboratory data currently unavailable</p>
        </div>
      )}
    </div>
  </section>

