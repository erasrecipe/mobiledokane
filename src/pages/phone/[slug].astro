<script is:inline define:vars={{ searchIndex, phoneName: phone.name, phoneSlug: phone.slug }}>
  // XSS-safe HTML escaping
  const esc = (str) => String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

  const expandBtn = document.getElementById('expand-btn');
  const overviewText = document.getElementById('overview-text');
  const expandIcon = document.getElementById('expand-icon');
  const expandLabel = document.getElementById('expand-label');

  if (expandBtn && overviewText && expandIcon && expandLabel) {
    expandBtn.addEventListener('click', () => {
      const isExpanded = overviewText.classList.contains('line-clamp-none');

      if (isExpanded) {
        overviewText.classList.remove('line-clamp-none');
        overviewText.classList.add('line-clamp-2');
        expandIcon.style.transform = 'rotate(0deg)';
        expandLabel.textContent = 'Read More';
      } else {
        overviewText.classList.remove('line-clamp-2');
        overviewText.classList.add('line-clamp-none');
        expandIcon.style.transform = 'rotate(180deg)';
        expandLabel.textContent = 'Show Less';
      }
    });
  }

  // Swatch interaction
  const swatches = document.querySelectorAll('.color-swatch');
  const mainImage = document.getElementById('main-phone-image');
  const colorName = document.getElementById('color-name');

  swatches.forEach(swatch => {
    swatch.addEventListener('click', (e) => {
      const target = e.currentTarget;
      const newImage = target.dataset.image;
      const name = target.title;

      // Update active state
      swatches.forEach(s => s.classList.remove('border-blue-600', 'ring-2', 'ring-blue-100'));
      target.classList.add('border-blue-600', 'ring-2', 'ring-blue-100');

      // Animate image switch
      if (mainImage && newImage) {
        mainImage.style.opacity = '0';
        setTimeout(() => {
          mainImage.src = newImage;
          mainImage.style.opacity = '1';
        }, 300);
      }

      if (colorName) colorName.textContent = name;
    });
  });

  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bars = entry.target.querySelectorAll('.rating-progress-bar');
        bars.forEach((bar) => {
          const el = bar;
          el.style.width = el.dataset.targetWidth || '0%';
          el.style.opacity = "1";
        });
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  const targetSection = document.querySelector('.expert-evaluation-section');
  if (targetSection) {
    observer.observe(targetSection);
  }

  // Sharing functions
  window.sharePhone = function(platform) {
    const pageUrl = window.location.href;
    const text = `Check out ${phoneName} - Price in Bangladesh: ${pageUrl}`;
    let url = '';
    switch(platform) {
      case 'facebook':
        url = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
        break;
      case 'twitter':
        url = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`;
        break;
      case 'whatsapp':
        url = `https://wa.me/?text=${encodeURIComponent(text)}`;
        break;
    }
    if (url) window.open(url, '_blank', 'width=600,height=400');
  };

  window.shareNative = async function() {
    if (navigator.share) {
      try {
        await navigator.share({
          title: phoneName,
          text: `Check out ${phoneName} price in Bangladesh`,
          url: window.location.href
        });
      } catch (e) {
        if (e.name !== 'AbortError') console.error(e);
      }
    }
  };

  // Similar Phones (uses lightweight search-index instead of full phones.json)
  const similarPhonesList = searchIndex
    .filter(p => p.s !== phoneSlug)
    .sort(() => 0.5 - Math.random())
    .slice(0, 4);

  if (similarPhonesList.length > 0) {
    const grid = document.getElementById('similar-phones-grid');
    if (grid) {
      grid.innerHTML = similarPhonesList.map(p => `
        <a href="/phone/${esc(p.s)}" class="group flex flex-col bg-white rounded-xl border border-slate-200 hover:border-blue-400 hover:shadow-lg transition-all duration-300 overflow-hidden shadow-sm">
          <div class="p-3 flex items-center justify-center bg-gradient-to-b from-slate-50 to-white">
            <img src="${esc(p.i)}" alt="${esc(p.n)} — product photo" class="h-24 sm:h-28 object-contain mix-blend-multiply group-hover:scale-105 transition-transform duration-300" loading="lazy" width="200" height="250" />
          </div>
          <div class="p-3 flex-1 flex flex-col">
            <h4 class="text-xs font-black text-slate-900 leading-tight mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">${esc(p.n)}</h4>
          </div>
        </a>
      `).join('');
    }
  }
</script>

