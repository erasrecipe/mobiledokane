---
import Layout from '../../layouts/Layout.astro';
import PhoneCard from '../../components/PhoneCard.astro';
import phones from '../../data/phones.json';

export function getStaticPaths() {
  return [
    { params: { range: '5k-10k' }, props: { min: 5000, max: 10000, label: '5,000 - 10,000 BDT' } },
    { params: { range: '10k-20k' }, props: { min: 10000, max: 20000, label: '10,000 - 20,000 BDT' } },
    { params: { range: '20k-40k' }, props: { min: 20000, max: 40000, label: '20,000 - 40,000 BDT' } },
    { params: { range: '40k-60k' }, props: { min: 40000, max: 60000, label: '40,000 - 60,000 BDT' } },
    { params: { range: '60k-100k' }, props: { min: 60000, max: 100000, label: '60,000 - 100,000 BDT' } },
    { params: { range: '100k-plus' }, props: { min: 100000, max: 1000000, label: 'Above 100,000 BDT' } },
  ];
}

const { range } = Astro.params;
const { min, max, label } = Astro.props;

const filteredPhones = phones.filter(p => p.prices.unofficial >= min && p.prices.unofficial < max);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Phones Under ${label}`,
  "itemListElement": filteredPhones.map((phone, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Product",
      "name": phone.name,
      "url": `https://mobiledokane.com/phone/${phone.slug}`,
      "image": phone.image,
      "offers": {
        "@type": "Offer",
        "price": phone.prices.unofficial,
        "priceCurrency": "BDT"
      }
    }
  }))
};
---

<Layout title={`Mobile Phones Under ${label} Price in Bangladesh - Mobile Dokane`} description={`Found ${filteredPhones.length} models in the ${label} range. Every price is verified against current market stock in Bangladesh.`}>
  <Fragment slot="head">
    {filteredPhones.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
  </Fragment>
    <section class="bg-white border-b border-slate-200 py-16">
        <div class="max-w-6xl mx-auto px-6 text-center lg:text-left">
            <nav class="flex items-center justify-center lg:justify-start gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-8">
                <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
                <span>/</span>
                <span class="text-slate-900">Price Range</span>
                <span>/</span>
                <span class="text-blue-600">{label}</span>
            </nav>
            
            <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tighter uppercase leading-none">
                {label}
            </h1>
            <p class="mt-6 text-lg font-bold text-slate-500 max-w-2xl mx-auto lg:mx-0">
                Found {filteredPhones.length} models matching your budget. Every price is verified against current market stock in Bangladesh.
            </p>
        </div>
    </section>

    <section class="bg-[#eeeeee] py-20 min-h-screen">
        <div class="max-w-6xl mx-auto px-6">
            {filteredPhones.length > 0 ? (
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
                    {filteredPhones.map((phone) => (
                        <PhoneCard phone={phone} />
                    ))}
                </div>
            ) : (
                <div class="bg-white p-20 rounded-3xl border border-dashed border-slate-200 text-center">
                    <p class="text-slate-400 font-black uppercase tracking-widest text-sm italic">No models found in this price range yet.</p>
                </div>
            )}
        </div>
    </section>
</Layout>
