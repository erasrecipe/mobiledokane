---
import Layout from '../layouts/Layout.astro';

const officeLocation = "Level 1, Block B, Bashundhara City Shopping Mall, Panthapath, Dhaka";
const email = "support@mobiledokane.com.bd";
const phone = "+880 1XXX-XXXXXX";
---

<Layout title="Contact Us - Mobile Dokane | Mobile Price Tracker Bangladesh" description="Get in touch with the Mobile Dokane team. Email, phone, or visit our office in Bashundhara City, Dhaka. We respond within 24 hours.">
  
  <!-- CONTACT HERO -->
  <section class="bg-white py-24 border-b border-slate-200 relative overflow-hidden text-center">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-50 rounded-full blur-[120px] opacity-50 -mr-40 -mt-40"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-blue-700 text-[10px] font-black uppercase tracking-[0.2em] rounded-full mb-8">
        Get In Touch
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tighter mb-8 uppercase leading-none">
        We're Here to <span class="text-blue-600">Help.</span>
      </h1>
      <p class="text-xl text-slate-500 font-bold leading-relaxed max-w-2xl mx-auto">
        Have a question about a price? Noticed a data error? Or just want to say hi? Reach out to the Mobile Dokane team.
      </p>
    </div>
  </section>

  <!-- CONTACT CONTENT -->
  <section class="bg-[#eeeeee] py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-16">
        
        <!-- Contact Form -->
        <div class="lg:col-span-7">
          <div class="bg-white p-8 sm:p-12 rounded-[2.5rem] border border-slate-200 shadow-sm">
            <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-8">Send a Message</h2>
            <form id="contact-form" class="space-y-6" novalidate>
              <div id="form-status" class="hidden rounded-xl px-4 py-3 text-sm font-bold"></div>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="contact-name" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Full Name</label>
                  <input id="contact-name" name="name" type="text" required minlength="2" placeholder="John Doe" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl px-5 py-3 text-sm font-bold focus:border-blue-600 focus:bg-white outline-none transition-all" />
                </div>
                <div>
                  <label for="contact-email" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Email Address</label>
                  <input id="contact-email" name="email" type="email" required placeholder="john@example.com" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl px-5 py-3 text-sm font-bold focus:border-blue-600 focus:bg-white outline-none transition-all" />
                </div>
              </div>
              <div>
                <label for="contact-subject" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Subject</label>
                <input id="contact-subject" name="subject" type="text" required placeholder="Data Correction / General Inquiry" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl px-5 py-3 text-sm font-bold focus:border-blue-600 focus:bg-white outline-none transition-all" />
              </div>
              <div>
                <label for="contact-message" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Your Message</label>
                <textarea id="contact-message" name="message" rows="5" required minlength="10" placeholder="How can we help you today?" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl px-5 py-3 text-sm font-bold focus:border-blue-600 focus:bg-white outline-none transition-all resize-none"></textarea>
              </div>
              <button id="contact-submit" type="submit" class="w-full bg-slate-900 text-white font-black py-4 rounded-xl uppercase tracking-widest text-xs hover:bg-blue-600 hover:scale-[1.02] transition-all shadow-xl shadow-slate-200 disabled:opacity-50 disabled:cursor-not-allowed">
                Send Inquiry
              </button>
              <p class="text-[10px] font-bold text-slate-400 leading-relaxed text-center">
                By submitting this form, you agree to our <a href="/privacy" class="text-blue-600 underline hover:text-blue-800 transition-colors">Privacy Policy</a>. We will only use your information to respond to your inquiry.
              </p>
            </form>
          </div>
        </div>

        <!-- Info Panels -->
        <div class="lg:col-span-5 space-y-8">
          
          <!-- Location -->
          <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm">
            <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-2">Our Base</h3>
            <p class="text-sm font-bold text-slate-500 leading-relaxed">{officeLocation}</p>
          </div>

          <!-- Direct Channels -->
          <div class="bg-slate-900 text-white p-8 rounded-[2.5rem] border border-slate-800 shadow-xl shadow-slate-200">
            <h3 class="text-xl font-black uppercase tracking-tight mb-6">Direct Channels</h3>
            <div class="space-y-6">
              <div class="flex items-center gap-4">
                <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center text-blue-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                </div>
                <div>
                  <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Email</p>
                  <p class="text-sm font-bold">{email}</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center text-green-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                </div>
                <div>
                  <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Support</p>
                  <p class="text-sm font-bold">{phone}</p>
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xwvaeded';
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status');
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

  if (form && statusEl && submitBtn) {
    const showError = (msg: string) => {
      statusEl.classList.remove('hidden', 'bg-green-50', 'text-green-700', 'border', 'border-green-200');
      statusEl.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
      statusEl.textContent = msg;
    };

    const showSuccess = (msg: string) => {
      statusEl.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'border', 'border-red-200');
      statusEl.classList.add('bg-green-50', 'text-green-700', 'border', 'border-green-200');
      statusEl.textContent = msg;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
      const subject = (document.getElementById('contact-subject') as HTMLInputElement).value.trim();
      const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();

      if (!name || name.length < 2) return showError('Please enter your full name (at least 2 characters).');
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return showError('Please enter a valid email address.');
      if (!subject || subject.length < 2) return showError('Please enter a subject.');
      if (!message || message.length < 10) return showError('Please write a message (at least 10 characters).');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const response = await fetch(FORMSPREE_ENDPOINT, {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, subject, message })
        });

        if (response.ok) {
          showSuccess('Thank you! Your message has been sent. We will respond within 24 hours.');
          form.reset();
        } else {
          const data = await response.json();
          showError(data.error || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        showError('Network error. Please check your connection and try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Inquiry';
      }
    });

    // Real-time validation feedback
    const fields = ['contact-name', 'contact-email', 'contact-subject', 'contact-message'];
    fields.forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
      el?.addEventListener('blur', () => {
        if (el.value.trim().length > 0) {
          el.classList.add('border-green-300');
          el.classList.remove('border-slate-100', 'border-red-300');
        }
      });
      el?.addEventListener('input', () => {
        el.classList.remove('border-red-300', 'border-green-300');
        el.classList.add('border-slate-100');
      });
    });
  }
</script>
