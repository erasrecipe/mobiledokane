const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Mobile Dokane",
  "url": "https://mobiledokane.com",
  "logo": "https://mobiledokane.com/logo.png",
  "description": "Bangladesh's most advanced mobile phone price aggregator with verified specs, benchmarks, and real-time BDT pricing.",
  "foundingDate": "2026",
  "founder": {
    "@type": "Person",
    "name": "Md. Mehrab Musa"
  },
  "sameAs": [
    "https://www.facebook.com/share/17fid12Sst/",
    "https://x.com/the_mehrab_musa",
    "https://www.instagram.com/the_mehrab_musa"
  ],
