---
import Layout from '../layouts/Layout.astro';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Mobile Dokane",
  "url": "https://mobiledokane.com",
  "logo": "https://mobiledokane.com/logo.png",
  "description": "Bangladesh's most advanced mobile phone price aggregator with verified specs, benchmarks, and real-time BDT pricing.",
  "foundingDate": "2026",
  "founder": {
    "@type": "Person",
    "name": "Md. Mehrab Musa"
  },
  "sameAs": [
    "https://www.facebook.com/share/17fid12Sst/",
    "https://x.com/the_mehrab_musa",
    "https://www.instagram.com/the_mehrab_musa"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Support",
    "email": "support@mobiledokane.com.bd",
    "areaServed": "BD",
    "availableLanguage": ["en", "bn"]
  }
};
---

<Layout title="About Us - Mobile Dokane | Phone Price Tracker Bangladesh" description="Mobile Dokane is Bangladesh's most advanced mobile phone price aggregator. We track verified specs, benchmarks, and real-time BDT pricing from Dhaka's top markets.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </Fragment>
  
  <!-- ABOUT HERO -->
  <section class="bg-white py-24 border-b border-slate-200 relative overflow-hidden text-center">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-50 rounded-full blur-[120px] opacity-50 -mr-40 -mt-40"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-blue-700 text-[10px] font-black uppercase tracking-[0.2em] rounded-full mb-8">
        Our Mission
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tighter mb-8 uppercase leading-none">
        Empowering Your <span class="text-blue-600">Decision.</span>
      </h1>
      <p class="text-xl text-slate-500 font-bold leading-relaxed">
        Mobile Dokane is Bangladesh's first data-driven mobile price aggregator. Our motto is simple: <span class="text-slate-900 underline decoration-blue-500 decoration-4 underline-offset-4 italic">find your favorite phone</span> without the marketing noise.
      </p>
    </div>
  </section>

  <!-- THE STORY SECTION -->
  <section class="bg-[#eeeeee] py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter mb-6">Real-Time Data, Real Savings</h2>
          <div class="space-y-6 text-slate-600 font-medium leading-relaxed text-base">
            <p>
              In the fast-paced mobile market of Bangladesh, prices change by the hour. Traditional websites often show outdated official rates that don't reflect the reality of major hubs like <span class="text-slate-900 font-black">Bashundhara City</span> or <span class="text-slate-900 font-black">Jamuna Future Park</span>.
            </p>
            <p>
              Founded in 2026, Mobile Dokane was built to solve this. We are not a shop. We are a technical decision engine. We aggregate raw data from over 50 trusted retailers to show you exactly what a phone costs right now—both official and unofficial.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm text-center">
            <p class="text-4xl font-black text-blue-600 mb-2">2.5k+</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Verified Models</p>
          </div>
          <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm text-center">
            <p class="text-4xl font-black text-slate-900 mb-2">50+</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Trusted Shops</p>
          </div>
          <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm text-center col-span-2">
            <p class="text-4xl font-black text-green-600 mb-2">Daily</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Market Updates</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE VERIFY DATA -->
  <section class="bg-white py-24 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter mb-4">How We Verify Data</h2>
        <p class="text-slate-500 font-bold uppercase text-[10px] tracking-[0.3em]">Our Technical Pipeline</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: "Direct Market Scanning", desc: "Our team manually verifies prices from top retail points daily to capture the real 'street price'." },
          { title: "Synthetic Benchmarking", desc: "We run actual laboratory tests (AnTuTu, Geekbench) on retail units to verify manufacturer claims." },
          { title: "Community Feedback", desc: "We cross-reference our data with verified buyer reports to ensure shop reliability and stock status." }
        ].map(step => (
          <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100">
            <h3 class="text-lg font-black text-slate-900 uppercase mb-4 leading-tight">{step.title}</h3>
            <p class="text-sm font-bold text-slate-500 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OUR VISION -->
  <section class="bg-[#eeeeee] py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tighter mb-8 text-center">Our Vision</h2>
      <p class="text-lg font-bold text-slate-600 leading-relaxed mb-12">
        "To become the definitive source of technical truth for mobile consumers in South Asia, empowering every individual to make data-backed decisions that save them time and money."
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {["100% Unbiased", "User-First", "Data-Driven"].map(val => (
          <div class="bg-white py-4 px-6 rounded-2xl border border-slate-200 font-black uppercase text-xs tracking-widest text-slate-900 shadow-sm">{val}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- OUR MOTIVE -->
  <section class="bg-white py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tighter mb-8">Our Motive</h2>
      <div class="space-y-6 text-lg font-medium text-slate-600 leading-relaxed">
        <p>
          We believe that technology should be accessible, understandable, and transparent. The mobile industry is often clouded by aggressive marketing and opaque pricing, making it difficult for the average consumer to make informed choices.
        </p>
        <p>
          Our motive is to strip away the noise. By providing verified specifications, honest performance benchmarks, and real-time market data, we aim to bridge the gap between complex technical jargon and practical consumer needs.
        </p>
        <p>
          We aren't just building a price tracker; we are cultivating a community of informed users who value data, honesty, and efficiency in their digital lives.
        </p>
      </div>
    </div>
  </section>
</Layout>
